{
    "name": "School of Hip Hop",

    "assetManifest": [
        {"id": "intro-pandora-logo", "src": "assets/images/intro/intro-pandora-logo.png"},
        {"id": "intro-rote-logo", "src": "assets/images/intro/intro-rote-logo.png"},
        {"id": "intro-banner", "src": "assets/images/intro/intro-banner.png"},
        {"id": "intro-record-light", "src": "assets/images/intro/intro-record-light.png"},
        {"id": "intro-record", "src": "assets/images/intro/intro-record.png"},
        {"id": "intro-record-bg", "src": "assets/images/intro/intro-record-bg.png"},
        {"id": "intro-record-arm", "src": "assets/images/intro/intro-record-arm.png"},
        {"id": "intro-record", "src": "assets/images/intro/intro-bg.jpg"}
    ],

    "modulename": "intro",

    "colors": {
        "backgroundColor": "#683c7c"
    },

    "roleChooserLabel": "Enter your name and select your role.",

    "elements": [

        {
            "id": "intro-txt-container",
            "el": "<div><h1 id='txt-intro-welcome'>Welcome to the School of</h1><div id='img-intro-banner'></div><h1 id='txt-intro-subhead'>pre-sale at Pandora</h1></div>",
            "props": {
                "top": "100px"
            }
        },
        {
            "id": "intro-record-container",
            "el": "<div><div id='img-intro-record-bg'></div><div id='img-intro-record-disc'></div><div id='img-intro-record-light'></div><div id='img-intro-record-arm'></div></div>",
            "props": {
                "top": "45%",
                "marginTop": "-130px",
                "scale": 0.9
            }
        },
        {
            "id": "img-pandora-logo",
            "el": "<img src='assets/images/intro/intro-pandora-logo.png'/>",
            "props": {
                "right": "25px",
                "marginRight": "0px",
                "top": "25px"
            }
        },

        {
            "id": "img-rote-logo",
            "el": "<img src='assets/images/intro/intro-rote-logo.png'/>",
            "props": {
                "bottom": "150px",
                "left": "50%",
                "marginLeft": "-112px",
                "scale": 1.4
            }
        },
        {
            "id": "txt-intro-maximize-browser",
            "class": "intro-text horizontal-center",
            "el": "<h2>For the best experience,<br>maximize your browser window!</h2>",
            "props": {
                "top": "300px"
            }
        }
    ],


    "enter": [
        {
            "id": "img-rote-logo",
            "type": "from",
            "duration": 2,
            "startTime": 1,
            "props": {
                "autoAlpha": 0
            }
        },
        {
            "type": "group",
            "tweens": [
                {
                    "id": "img-pandora-logo",
                    "type": "from",
                    "duration": 1.5,
                    "props": {
                        "top": "300px",
                        "right": "50%",
                        "marginRight": "-70px",
                        "ease": "Circ.easeOut"
                    }
                },
                {
                    "id": "img-rote-logo",
                    "type": "to",
                    "duration": 1.5,
                    "props": {
                        "bottom": "0px",
                        "left": "0%",
                        "marginLeft": "0px",
                        "scale": 1,
                        "ease": "Circ.easeOut"
                    }
                }
            ]
        },
        {
            "id": "txt-intro-welcome",
            "type": "from",
            "duration": 0.6,
            "props": {
                "autoAlpha": 0
            }

        },
        {
            "id": "img-intro-banner",
            "type": "from",
            "startTime": "+=1",
            "duration": 0.9,
            "props": {
                "autoAlpha": 0
            }
        },

        {
            "id": "txt-intro-subhead",
            "type": "from",
            "duration": 0.6,
            "props": {
                "autoAlpha": 0
            }

        },
        {
            "id": "intro-txt-container",
            "type": "to",
            "duration": 0.6,
            "props": {
                "scale": 0.35,
                "transformOrigin": "center top",
                "top": "30px"
            }

        },
        {
            "id": "intro-record-container",
            "type": "from",
            "duration": 0.6,
            "props": {
                "top": "100%",
                "autoAlpha": 0
            }

        },
        {
            "id": "img-intro-record-arm",
            "type": "from",
            "duration": 1.5,
            "props": {
                "rotation": "-30deg",
                "transformOrigin": "357px 121px"
            }
        },

        {
            "id": "",
            "startTime": "+=1",
            "type": "callback",
            "callback": "playLoop"
        },

        {
            "id": "intro-rolechooser-container",
            "type": "from",
            "duration": 3,
            "startTime": "+=2",
            "props": {
                "autoAlpha": 0.0,
                "ease": "Linear.easeOut"
            }
        },
        {
            "id": "intro-continue-button",
            "type": "from",
            "duration": 0.5,
            "props": {
                "autoAlpha": 0.0
            }
        }

    ],
    "leave": [
        
        {
            "type": "group",
            "startTime": "+=0.5",
            "tweens": [
                {
                    "id": "intro-txt-container",
                    "type": "to",
                    "duration": 1.5,
                    "startTime": 0.3,
                    "props": {
                        "autoAlpha": 0.0
                    }
                },
                {
                    "id": "intro-record-container",
                    "type": "to",
                    "duration": 1.5,
                    "props": {
                        "autoAlpha": 0
                    }
                },
                {
                    "id": "intro-rolechooser-container",
                    "type": "to",
                    "duration": 0.5,
                    "props": {
                        "autoAlpha": 0
                    }
                },
                {
                    "id": "intro-continue-button",
                    "type": "to",
                    "duration": 0.5,
                    "props": {
                        "autoAlpha": 0
                    }
                }

            ]
        },
        {
            "id": "txt-intro-maximize-browser",
            "type": "from",
            "duration": 1.5,
            "props": {
                "autoAlpha": 0,
                "scale": 0.7
            }
        },
        {
            "id": "txt-intro-maximize-browser",
            "type": "to",
            "startTime": "+=4",
            "duration": 0.5,
            "props": {
                "autoAlpha": 0
            }
        }
    ]
}

