            ]
        },
        {
            "id": "s2",
            "bg_color": "#993333",
            "text": {
                "header": "Manual PYM Approval Cases",
                "body": "<p>Slingshot can't automate all PYM approval cases. It's sad, we know. The good news is is it does automate the majority of the PYM approvals you’ll need. Other types of approvals will still need Sales and Client Services to make manual approval cases within Salesforce or Matterhorn.</p><p class='pt-callout'>Click the notes to reveal each PYM approval that needs manual approval cases in Salesforce or Matterhorn.</p>",
                "class": "align-right pt-neg-margin-top"
            },
            "interaction": {
                "name": "cr_pym_s2",
                "id": "cr-pym-s2",
                "type": "clickReveal",
                "items": [
                    {
                        "header": "",
                        "body": "<p>Sponsorships (Matterhorn request)</p>"
                    },
                    {
                        "header": "",
                        "body": "<p>High Share of Voice (Matterhorn request)</p>"
                    },
                    {
                        "header": "",
                        "body": "<p>Product Minimum Spend (Salesforce approval case)</p>"
                    },
                    {
                        "header": "",
                        "body": "<p>Added Value is greater than 10 percent, or if it falls outside of Pandora’s Added Value Policy (Salesforce approval case)</p>"
                    },
                    {
                        "header": "",
                        "body": "<p>Inventory booking issues (Salesforce approval case)</p>"
                    },
                    {
                        "header": "",
                        "body": "<p>Makegoods (Salesforce approval case)</p>"
                    },
                    {
                        "header": "",
                        "body": "<p>Make wholes (Salesforce approval case)</p>"
                    },
                    {
                        "header": "",
                        "body": "<p>Probono (Salesforce approval case)</p>"
                    },
                    {
                        "header": "",
                        "body": "<p>Third party verification (Salesforce approval case)</p>"
                    },
                    {
                        "header": "",
                        "body": "<p>Under-delivery (Salesforce approval case)</p>"
                    }
                ]
            },
