                    "duration": 0.5,
                    "startTime": 0.3,
                    "props": {
                        "autoAlpha": 0
                    }
                },
                {
                    "id": "cr-pym-s1 .reveal-item",
                    "type": "staggerTo",
                    "duration": 0.3,
                    "startTime": 0.8,
                    "staggerOffset": 0.15,
                    "props": {
                        "autoAlpha": 0
